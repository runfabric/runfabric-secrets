{
  "name": "@runfabric/secrets",
  "private": true,
  "version": "0.1.0",
  "description": "Pluggable secrets toolkit monorepo",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "release:check": "node scripts/release-check.mjs",
    "verify:v1": "pnpm lint && pnpm test && pnpm typecheck && pnpm build && pnpm release:check",
    "verify:v2": "pnpm lint && pnpm test && pnpm typecheck && pnpm build && pnpm release:check"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "pnpm": "^10.0.0",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
